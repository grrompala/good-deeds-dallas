# Copy to .env.local and fill in. .env.local is gitignored by Next.js.
# Everything here is SERVER-SIDE ONLY. Do NOT prefix with NEXT_PUBLIC — that
# would leak the value to the browser.

# OpenAI (embeddings + chat).
OPENAI_API_KEY=sk-your-key-here

# Supabase (pgvector store). Use the SECRET key (sb_secret_...), not the
# publishable one. URL + key are in Project Settings → API / API Keys.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=sec_jey

# Optional overrides (defaults shown). Swap models without touching code.
RAG_EMBED_MODEL=text-embedding-3-small
RAG_CHAT_MODEL=gpt-4o-mini
# Embedding size. MUST match the vector(N) column in supabase/schema.sql.
RAG_EMBED_DIMS=256
RAG_TOP_K=8
