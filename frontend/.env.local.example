# Copy to .env.local and fill in. .env.local is gitignored by Next.js.

# Required — server-side only. Do NOT prefix with NEXT_PUBLIC (that would leak
# the key to the browser).
OPENAI_API_KEY=sk-your-key-here

# Optional model overrides (defaults shown). Change these to swap models
# without touching code.
RAG_EMBED_MODEL=text-embedding-3-small
RAG_CHAT_MODEL=gpt-4o-mini
RAG_TOP_K=1
