node_modules/
.next/
out/
.npm
*.log
.pnp
.pnp.js
.yarn/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.ipynb_checkpoints/

